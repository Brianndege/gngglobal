# GNG Global Investment Group - Environment Variables
# Copy this file to .env.local and fill in the values

# Site URL (used for OpenGraph metadata)
NEXT_PUBLIC_SITE_URL=https://gngglobal.com.au

# Contact Form API (optional - configure if using a form backend)
# CONTACT_FORM_ENDPOINT=https://your-form-endpoint.com/api/contact

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
